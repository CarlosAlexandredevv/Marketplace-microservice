{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "moduleNameMapper": {
    "^src/(.*)$": "<rootDir>/../src/$1"
  },
  "setupFiles": ["<rootDir>/jest-e2e-setup.ts"],
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "testPathIgnorePatterns": [
    "gateway-users-live",
    "gateway-checkout-live",
    "gateway-payments-live"
  ],
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  }
}
